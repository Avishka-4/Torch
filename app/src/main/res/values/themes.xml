<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TorchApp" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/torch_on</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_dark</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/background_dark</item>
        <!-- Action bar -->
        <item name="actionBarStyle">@style/TorchActionBar</item>
    </style>
    
    <style name="TorchActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="android:background">@color/surface_dark</item>
        <item name="background">@color/surface_dark</item>
        <item name="titleTextStyle">@style/TorchActionBarTitle</item>
    </style>
    
    <style name="TorchActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>